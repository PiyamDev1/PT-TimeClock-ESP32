# Copy to local.env and fill values
# cp local.env.example local.env

# GitHub fine-grained PAT (repo contents: read)
PTC_GITHUB_TOKEN=

# Timeclock backend base URL, without a trailing slash
PTC_API_BASE_URL=https://ims.piyamtravel.com

# Physical device row from PT-Portal's timeclock_devices table
PTC_DEVICE_ID=
PTC_DEVICE_SECRET=
PTC_DEVICE_LOCATION=

# Optional first-boot Wi-Fi written to a blank SD card
PTC_DEFAULT_WIFI_SSID=
PTC_DEFAULT_WIFI_PASSWORD=
